# Blockchain RPC endpoints (public, no key required)
ETHEREUM_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed1.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Etherscan V2 API (single key, all chains)
# Register free at https://etherscan.io/myapikey — 5 calls/sec free tier
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE

# Application config
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://audit_user:audit_pass@localhost:5432/smart_contract_audit

# Redis
REDIS_URL=redis://localhost:6379
